{
  "manifest_version": 3,
  "name": "LexiSide — Vocabulary Sidebar",
  "version": "1.0.0",
  "description": "Save words while browsing, get translations in up to 4 languages, and build your personal vocabulary list.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "action": {
    "default_title": "Open LexiSide"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
